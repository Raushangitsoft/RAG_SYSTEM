# Copy this file to .env and update values

APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

POSTGRES_USER=raguser
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=ragdb
DATABASE_URL=postgresql+asyncpg://raguser:change_this_password@postgres:5432/ragdb

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_PORT=6333

ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8192

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
EMBEDDING_DIMENSION=1024

RERANKER_MODEL=BAAI/bge-reranker-large
RERANKER_DEVICE=cpu

HYBRID_SEARCH_TOP_K=50

DOCUMENTS_BASE_PATH=/app/data/documents
MODELS_BASE_PATH=/app/data/models
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=pdf,docx,pptx,xlsx,txt

SECRET_KEY=change_this_to_a_random_64_char_string
